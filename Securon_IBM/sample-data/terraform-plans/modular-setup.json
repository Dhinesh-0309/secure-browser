{
  "format_version": "1.2",
  "terraform_version": "1.6.0",
  "planned_values": {
    "root_module": {
      "child_modules": [
        {
          "address": "module.vpc",
          "resources": [
            {
              "address": "module.vpc.aws_vpc.main",
              "mode": "managed",
              "type": "aws_vpc",
              "name": "main",
              "provider_name": "registry.terraform.io/hashicorp/aws",
              "schema_version": 1,
              "values": {
                "cidr_block": "10.0.0.0/16",
                "enable_dns_hostnames": true,
                "enable_dns_support": true,
                "tags": {
                  "Name": "main-vpc",
                  "Environment": "production"
                }
              }
            },
            {
              "address": "module.vpc.aws_subnet.public",
              "mode": "managed",
              "type": "aws_subnet",
              "name": "public",
              "provider_name": "registry.terraform.io/hashicorp/aws",
              "schema_version": 1,
              "values": {
                "cidr_block": "10.0.1.0/24",
                "availability_zone": "us-west-2a",
                "map_public_ip_on_launch": true,
                "tags": {
                  "Name": "public-subnet",
                  "Type": "public"
                }
              }
            }
          ]
        },
        {
          "address": "module.security",
          "resources": [
            {
              "address": "module.security.aws_security_group.app_sg",
              "mode": "managed",
              "type": "aws_security_group",
              "name": "app_sg",
              "provider_name": "registry.terraform.io/hashicorp/aws",
              "schema_version": 1,
              "values": {
                "name": "application-security-group",
                "description": "Security group for application servers",
                "ingress": [
                  {
                    "from_port": 8080,
                    "to_port": 8080,
                    "protocol": "tcp",
                    "security_groups": ["sg-web-tier"]
                  }
                ],
                "egress": [
                  {
                    "from_port": 0,
                    "to_port": 0,
                    "protocol": "-1",
                    "cidr_blocks": ["0.0.0.0/0"]
                  }
                ]
              }
            }
          ]
        },
        {
          "address": "module.database",
          "resources": [
            {
              "address": "module.database.aws_db_instance.main",
              "mode": "managed",
              "type": "aws_db_instance",
              "name": "main",
              "provider_name": "registry.terraform.io/hashicorp/aws",
              "schema_version": 1,
              "values": {
                "allocated_storage": 20,
                "engine": "mysql",
                "engine_version": "8.0",
                "instance_class": "db.t3.micro",
                "db_name": "appdb",
                "username": "admin",
                "password": "changeme123",
                "storage_encrypted": false,
                "publicly_accessible": true,
                "tags": {
                  "Name": "main-database",
                  "Environment": "production"
                }
              }
            }
          ]
        }
      ]
    }
  },
  "configuration": {
    "root_module": {
      "module_calls": {
        "vpc": {
          "source": "./modules/vpc",
          "expressions": {
            "cidr_block": {
              "constant_value": "10.0.0.0/16"
            },
            "environment": {
              "constant_value": "production"
            }
          }
        },
        "security": {
          "source": "./modules/security",
          "expressions": {
            "vpc_id": {
              "references": ["module.vpc.vpc_id"]
            }
          }
        },
        "database": {
          "source": "./modules/database",
          "expressions": {
            "subnet_group": {
              "references": ["module.vpc.database_subnet_group"]
            },
            "security_group_ids": {
              "references": ["module.security.database_sg_id"]
            }
          }
        }
      }
    }
  }
}